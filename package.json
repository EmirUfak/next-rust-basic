{
  "name": "next-rust-basic",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/maybe-build-wasm.mjs",
    "predev:shared": "cross-env WASM_SHARED=1 node scripts/maybe-build-wasm.mjs",
    "dev": "next dev --webpack",
    "dev:shared": "next dev --webpack",
    "prebuild": "node scripts/maybe-build-wasm.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "analyze": "cross-env ANALYZE=true next build",
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:wasm:shared": "cross-env WASM_SHARED=1 node scripts/build-wasm.mjs",
    "postinstall": "node scripts/maybe-build-wasm.mjs",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "next": "16.2.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "binaryen": "^125.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^24.1.3",
    "tailwindcss": "^4.3.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
